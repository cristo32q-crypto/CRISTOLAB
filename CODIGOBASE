  <!-- FOOTER -->
  <footer>
    <div class="footer-logo">CRISTOLAB 2.0</div>
    <div class="footer-text">© 2025 Laboratorio Virtual de Mantenimiento Industrial. Todos los derechos reservados.</div>
    <div style="font-size:11px; color:var(--muted);">v2.0.1 · ISO 9001</div>
  </footer>

  <script>
    /* ===== NAVEGACIÓN ===== */
    function showSection(id, btn) {
      document.querySelectorAll('.section').forEach(s => s.classList.remove('visible'));
      document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
      document.getElementById(id).classList.add('visible');
      if (btn) btn.classList.add('active');
      if (id === 'lab') setTimeout(initCanvas, 60);
      window.scrollTo({ top: 0, behavior: 'smooth' });
      // Cerrar menú móvil
      document.getElementById('navLinks').classList.remove('open');
    }

    function toggleMenu() {
      document.getElementById('navLinks').classList.toggle('open');
    }

    /* ===== DATOS DE METALES ===== */
    const metals = [
      {
        id: 'acero', name: 'Acero al Carbono', symbol: 'Fe-C',
        color: [180, 200, 220], shininess: 0.88,
        desc: 'Material estructural más utilizado en la industria. Aleación de hierro y carbono con excelentes propiedades mecánicas y amplia disponibilidad.',
        props: {
          'Densidad': '7,850 kg/m³',
          'Dureza': '120–200 HB',
          'Resistencia a Tracción': '400–800 MPa',
          'Módulo de Young': '210 GPa',
          'Conductividad Térmica': '50 W/m·K',
          'Punto de Fusión': '1,430–1,530 °C'
        }
      },
      {
        id: 'aluminio', name: 'Aluminio 6061-T6', symbol: 'Al',
        color: [205, 215, 235], shininess: 0.96,
        desc: 'Aleación ligera de alta resistencia, excelente maquinabilidad y resistencia a la corrosión. Ampliamente usado en industria aeronáutica y automotriz.',
        props: {
          'Densidad': '2,700 kg/m³',
          'Dureza': '95 HB',
          'Resistencia a Tracción': '310 MPa',
          'Módulo de Young': '69 GPa',
          'Conductividad Térmica': '167 W/m·K',
          'Punto de Fusión': '582–652 °C'
        }
      },
      {
        id: 'cobre', name: 'Cobre C110', symbol: 'Cu',
        color: [205, 122, 60], shininess: 0.84,
        desc: 'Excelente conductor eléctrico y térmico. Base de aleaciones como bronce y latón. Alta resistencia a la corrosión en ambientes industriales.',
        props: {
          'Densidad': '8,940 kg/m³',
          'Dureza': '35 HB',
          'Resistencia a Tracción': '220 MPa',
          'Módulo de Young': '120 GPa',
          'Conductividad Térmica': '401 W/m·K',
          'Punto de Fusión': '1,085 °C'
        }
      },
      {
        id: 'inox', name: 'Acero Inoxidable 304', symbol: 'AISI 304',
        color: [192, 198, 210], shininess: 1.0,
        desc: 'Aleación hierro-cromo-níquel con alta resistencia a la corrosión y oxidación. Estándar en industria alimentaria, farmacéutica y química.',
        props: {
          'Densidad': '8,000 kg/m³',
          'Dureza': '201 HB',
          'Resistencia a Tracción': '515 MPa',
          'Módulo de Young': '193 GPa',
          'Conductividad Térmica': '16 W/m·K',
          'Punto de Fusión': '1,399–1,454 °C'
        }
      },
      {
        id: 'titanio', name: 'Titanio Ti-6Al-4V', symbol: 'Ti',
        color: [148, 158, 182], shininess: 0.78,
        desc: 'Alta resistencia específica (relación peso/resistencia). Biocompatible, resistente a altas temperaturas y excelente resistencia a corrosión.',
        props: {
          'Densidad': '4,430 kg/m³',
          'Dureza': '334 HB',
          'Resistencia a Tracción': '950 MPa',
          'Módulo de Young': '114 GPa',
          'Conductividad Térmica': '6.7 W/m·K',
          'Punto de Fusión': '1,604–1,660 °C'
        }
      }
    ];

    let currentMetal = metals[0];
    let rotX = 0.4, rotY = 0, autoRot = true;
    let isDrag = false, lastX = 0, lastY = 0, zoom = 1;
    let animFrame, canvas, ctx;

    /* ===== SELECTORES ===== */
    function buildSelectors() {
      const container = document.getElementById('metalSelector');
      metals.forEach((m, i) => {
        const btn = document.createElement('button');
        btn.className = 'metal-btn' + (i === 0 ? ' active' : '');
        btn.textContent = m.name;
        btn.onclick = () => {
          document.querySelectorAll('.metal-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          currentMetal = m;
          rotX = 0.4; rotY = 0;
          updateInfo();
        };
        container.appendChild(btn);
      });
    }

    function updateInfo() {
      const m = currentMetal;
      document.getElementById('metalTitle').textContent = '⬡ ' + m.symbol + ' — ' + m.name;
      let html = `
        <div class="metal-name">${m.name}</div>
        <div class="metal-symbol">${m.symbol}</div>
        <div class="metal-desc">${m.desc}</div>
      `;
      for (const [k, v] of Object.entries(m.props)) {
        html += `<div class="prop-row"><span>${k}</span><span>${v}</span></div>`;
      }
      document.getElementById('metalInfo').innerHTML = html;
    }

    /* ===== RENDERIZADO 3D ===== */
    function project(x, y, z, cx, cy) {
      const cosX = Math.cos(rotX), sinX = Math.sin(rotX);
      const cosY = Math.cos(rotY), sinY = Math.sin(rotY);
      const x2 = x * cosY + z * sinY;
      const z2 = -x * sinY + z * cosY;
      const y2 = y * cosX - z2 * sinX;
      const z3 = y * sinX + z2 * cosX;
      const scale = zoom * (88 + z3 * 0.28);
      return { x: cx + x2 * scale, y: cy + y2 * scale, z: z3 };
    }

    function drawScene() {
      if (!canvas || !ctx) return;
      const w = canvas.width, h = canvas.height;
      ctx.clearRect(0, 0, w, h);
      const cx = w / 2, cy = h / 2 - 8;
      const m = currentMetal;
      const R = m.color[0], G = m.color[1], B = m.color[2];

      // Grid de referencia
      ctx.strokeStyle = 'rgba(0,194,255,0.06)';
      ctx.lineWidth = 0.5;
      for (let i = -3; i <= 3; i++) {
        const p1 = project(i * 0.28, -0.68, -0.88, cx, cy);
        const p2 = project(i * 0.28, -0.68, 0.88, cx, cy);
        ctx.beginPath(); ctx.moveTo(p1.x, p1.y); ctx.lineTo(p2.x, p2.y); ctx.stroke();
        const p3 = project(-0.88, -0.68, i * 0.28, cx, cy);
        const p4 = project(0.88, -0.68, i * 0.28, cx, cy);
        ctx.beginPath(); ctx.moveTo(p3.x, p3.y); ctx.lineTo(p4.x, p4.y); ctx.stroke();
      }

      // Reflexión sombra
      ctx.save();
      ctx.globalAlpha = 0.1;
      ctx.scale(1, -0.28);
      const adjCy = -(cy + 52) / 0.28;
      renderCube(cx, adjCy, R, G, B, m.shininess);
      ctx.restore();

      // Cubo principal
      renderCube(cx, cy, R, G, B, m.shininess);

      // Ejes
      const o = project(0, -0.68, 0, cx, cy);
      [
        [project(0.44, -0.68, 0, cx, cy), 'rgba(255,80,80,0.6)', 'X'],
        [project(0, -0.24, 0, cx, cy), 'rgba(80,255,80,0.6)', 'Y'],
        [project(0, -0.68, 0.44, cx, cy), 'rgba(80,160,255,0.6)', 'Z']
      ].forEach(([p, color, label]) => {
        ctx.strokeStyle = color; ctx.lineWidth = 1;
        ctx.beginPath(); ctx.moveTo(o.x, o.y); ctx.lineTo(p.x, p.y); ctx.stroke();
        ctx.fillStyle = color; ctx.font = '9px monospace';
        ctx.fillText(label, p.x + 3, p.y - 2);
      });

      // Símbolo del metal
      ctx.globalAlpha = 0.05;
      ctx.fillStyle = '#00C2FF';
      const symText = m.symbol.substring(0, 2);
      ctx.font = `bold ${h * 0.55}px Orbitron, monospace`;
      ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillText(symText, cx, cy);
      ctx.globalAlpha = 1;
      ctx.textAlign = 'left'; ctx.textBaseline = 'alphabetic';
    }

    function renderCube(cx, cy, R, G, B, shininess) {
      const verts = [];
      const s = 0.6;
      [-s, s].forEach(xi => [-s, s].forEach(yi => [-s, s].forEach(zi => {
        verts.push(project(xi, yi, zi, cx, cy));
      })));

      const faces = [
        { idx: [0, 1, 3, 2], norm: [0, 0, -1] },
        { idx: [4, 5, 7, 6], norm: [0, 0, 1] },
        { idx: [0, 2, 6, 4], norm: [-1, 0, 0] },
        { idx: [1, 3, 7, 5], norm: [1, 0, 0] },
        { idx: [0, 1, 5, 4], norm: [0, -1, 0] },
        { idx: [2, 3, 7, 6], norm: [0, 1, 0] }
      ];

      const lx = 0.6, ly = -0.75, lz = 0.6;
      const lLen = Math.sqrt(lx * lx + ly * ly + lz * lz);

      const faceData = faces.map(f => {
        const n = f.norm;
        const cosX = Math.cos(rotX), sinX = Math.sin(rotX);
        const cosY = Math.cos(rotY), sinY = Math.sin(rotY);
        const nx2 = n[0] * cosY + n[2] * sinY;
        const nz2 = -n[0] * sinY + n[2] * cosY;
        const ny2 = n[1] * cosX - nz2 * sinX;
        const nz3 = n[1] * sinX + nz2 * cosX;
        const dot = (nx2 * lx + ny2 * ly + nz3 * lz) / lLen;
        const br = 0.18 + 0.68 * Math.max(0, dot) + 0.14 * shininess * Math.max(0, Math.pow(dot, 4));
        const avgZ = f.idx.reduce((s, i) => s + verts[i].z, 0) / 4;
        return { ...f, br, avgZ, fverts: f.idx.map(i => verts[i]) };
      }).sort((a, b) => a.avgZ - b.avgZ);

      faceData.forEach(f => {
        const br = f.br;
        ctx.beginPath();
        ctx.moveTo(f.fverts[0].x, f.fverts[0].y);
        f.fverts.slice(1).forEach(v => ctx.lineTo(v.x, v.y));
        ctx.closePath();
        ctx.fillStyle = `rgb(${Math.round(R * br)},${Math.round(G * br)},${Math.round(B * br)})`;
        ctx.fill();
        ctx.strokeStyle = 'rgba(0,194,255,0.25)';
        ctx.lineWidth = 0.6;
        ctx.stroke();
      });
    }

    function initCanvas() {
      canvas = document.getElementById('metalCanvas');
      if (!canvas) return;
      const wrap = canvas.parentElement;
      canvas.width = wrap.offsetWidth || 400;
      canvas.height = wrap.offsetHeight || 220;
      ctx = canvas.getContext('2d');
      cancelAnimationFrame(animFrame);

      let lastTime = 0;
      function loop(t) {
        if (autoRot && !isDrag) rotY += 0.008;
        if (t - lastTime > 14) { drawScene(); lastTime = t; }
        animFrame = requestAnimationFrame(loop);
      }
      animFrame = requestAnimationFrame(loop);

      canvas.addEventListener('mousedown', e => {
        isDrag = true; lastX = e.clientX; lastY = e.clientY; autoRot = false;
        document.getElementById('rotLabel').textContent = 'Control manual';
      });
      canvas.addEventListener('mousemove', e => {
        if (!isDrag) return;
        rotY += (e.clientX - lastX) * 0.01;
        rotX += (e.clientY - lastY) * 0.01;
        lastX = e.clientX; lastY = e.clientY;
      });
      canvas.addEventListener('mouseup', () => { isDrag = false; autoRot = true; document.getElementById('rotLabel').textContent = 'Auto-rotando...'; });
      canvas.addEventListener('mouseleave', () => { isDrag = false; autoRot = true; });
      canvas.addEventListener('wheel', e => {
        zoom = Math.max(0.5, Math.min(2.2, zoom - e.deltaY * 0.001));
        e.preventDefault();
      }, { passive: false });

      canvas.addEventListener('touchstart', e => {
        isDrag = true; lastX = e.touches[0].clientX; lastY = e.touches[0].clientY; autoRot = false;
        e.preventDefault();
      }, { passive: false });
      canvas.addEventListener('touchmove', e => {
        if (!isDrag) return;
        rotY += (e.touches[0].clientX - lastX) * 0.01;
        rotX += (e.touches[0].clientY - lastY) * 0.01;
        lastX = e.touches[0].clientX; lastY = e.touches[0].clientY;
        e.preventDefault();
      }, { passive: false });
      canvas.addEventListener('touchend', () => { isDrag = false; autoRot = true; });
    }

    /* ===== INIT ===== */
    buildSelectors();
    updateInfo();

    // Iniciar canvas si la sección Lab es visible desde el inicio
    if (document.getElementById('lab').classList.contains('visible')) {
      initCanvas();
    }
  </script>
