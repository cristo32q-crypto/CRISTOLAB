<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CRISTOLAB 2.0 — Laboratorio Virtual de Mantenimiento Industrial</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.44.0/tabler-icons.min.css">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --cyan: #00C2FF;
      --cyan2: #00E5FF;
      --teal: #00FFD1;
      --dark: #060D1F;
      --dark2: #0D1A35;
      --dark3: #142244;
      --card: #0D1A35;
      --border: #1A3A6A;
      --text: #C8E6FF;
      --muted: #5A8AB0;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--dark);
      color: var(--text);
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ===== NAVBAR ===== */
    nav {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: rgba(6, 13, 31, 0.97);
      border-bottom: 1px solid var(--border);
      padding: 0 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 60px;
      backdrop-filter: blur(10px);
    }

    .logo {
      font-family: 'Orbitron', sans-serif;
      font-size: 20px;
      font-weight: 900;
      color: var(--cyan);
      letter-spacing: 2px;
      user-select: none;
    }

    .logo span { color: var(--teal); }

    .logo-ver {
      font-size: 11px;
      font-weight: 400;
      color: var(--muted);
      margin-left: 6px;
      font-family: 'Inter', sans-serif;
    }

    .nav-links {
      display: flex;
      gap: 4px;
    }

    .nav-btn {
      background: none;
      border: none;
      color: var(--muted);
      font-size: 11px;
      font-family: 'Inter', sans-serif;
      font-weight: 600;
      padding: 7px 14px;
      border-radius: 7px;
      cursor: pointer;
      transition: all 0.2s;
      letter-spacing: 0.8px;
      text-transform: uppercase;
    }

    .nav-btn:hover { color: var(--cyan); background: rgba(0, 194, 255, 0.08); }
    .nav-btn.active { color: var(--cyan); background: rgba(0, 194, 255, 0.12); }

    .hamburger {
      display: none;
      background: none;
      border: 1px solid var(--border);
      color: var(--cyan);
      padding: 6px 10px;
      border-radius: 7px;
      cursor: pointer;
      font-size: 18px;
    }

    /* ===== SECTIONS ===== */
    .section { display: none; min-height: calc(100vh - 60px); }
    .section.visible { display: block; }

    .section-content {
      padding: 2.5rem 2rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .sec-header { margin-bottom: 2rem; }
    .sec-tag {
      font-size: 11px;
      font-weight: 700;
      color: var(--teal);
      text-transform: uppercase;
      letter-spacing: 2.5px;
      margin-bottom: 0.5rem;
    }
    .sec-title {
      font-family: 'Orbitron', sans-serif;
      font-size: 26px;
      font-weight: 700;
      color: #fff;
    }
    .sec-sub {
      font-size: 14px;
      color: var(--muted);
      margin-top: 0.5rem;
      max-width: 560px;
      line-height: 1.6;
    }

    /* ===== HERO ===== */
    .hero {
      position: relative;
      min-height: 580px;
      display: flex;
      align-items: center;
      overflow: hidden;
      padding: 3rem 2rem;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, #060D1F 0%, #0D1A35 50%, #091a3a 100%);
    }

    .hero-grid {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(0, 194, 255, 0.07) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0, 194, 255, 0.07) 1px, transparent 1px);
      background-size: 44px 44px;
    }

    .hero-glow {
      position: absolute;
      width: 500px;
      height: 500px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(0, 194, 255, 0.06) 0%, transparent 70%);
      right: -80px;
      top: 50%;
      transform: translateY(-50%);
      pointer-events: none;
    }

    .hero-content {
      position: relative;
      z-index: 2;
      max-width: 52%;
    }

    .hero-tag {
      display: inline-block;
      background: rgba(0, 194, 255, 0.1);
      border: 1px solid rgba(0, 194, 255, 0.3);
      color: var(--cyan);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
      padding: 6px 16px;
      border-radius: 30px;
      margin-bottom: 1.5rem;
    }

    .hero h1 {
      font-family: 'Orbitron', sans-serif;
      font-size: 42px;
      font-weight: 900;
      line-height: 1.1;
      margin-bottom: 1.2rem;
      color: #fff;
    }

    .hero h1 .accent { color: var(--cyan); }

    .hero p {
      font-size: 15px;
      line-height: 1.75;
      color: var(--muted);
      max-width: 440px;
      margin-bottom: 2rem;
    }

    .hero-btns { display: flex; gap: 12px; flex-wrap: wrap; }

    .btn-primary {
      background: var(--cyan);
      color: #060D1F;
      font-weight: 700;
      font-size: 13px;
      padding: 13px 30px;
      border-radius: 9px;
      border: none;
      cursor: pointer;
      font-family: 'Orbitron', sans-serif;
      letter-spacing: 1px;
      transition: all 0.2s;
    }
    .btn-primary:hover { background: var(--cyan2); transform: translateY(-2px); }

    .btn-secondary {
      background: rgba(0, 194, 255, 0.1);
      color: var(--cyan);
      font-weight: 600;
      font-size: 13px;
      padding: 12px 26px;
      border-radius: 9px;
      border: 1px solid rgba(0, 194, 255, 0.3);
      cursor: pointer;
      font-family: 'Inter', sans-serif;
      transition: all 0.2s;
    }
    .btn-secondary:hover { background: rgba(0, 194, 255, 0.2); }

    .hero-stats {
      display: flex;
      gap: 2rem;
      margin-top: 2rem;
      flex-wrap: wrap;
    }

    .stat-num {
      font-family: 'Orbitron', sans-serif;
      font-size: 24px;
      font-weight: 700;
      color: var(--cyan);
    }
    .stat-label {
      font-size: 10px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 1.5px;
      margin-top: 2px;
    }

    .stat-divider { width: 1px; background: var(--border); }

    .hero-visual {
      position: absolute;
      right: 3rem;
      top: 50%;
      transform: translateY(-50%);
      width: 300px;
      height: 300px;
    }

    /* ===== CARDS GRID ===== */
    .cards-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 18px;
      margin-bottom: 2rem;
    }

    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.4rem;
      transition: all 0.25s;
      cursor: pointer;
    }
    .card:hover { border-color: var(--cyan); transform: translateY(-3px); }

    .card-icon {
      width: 44px;
      height: 44px;
      border-radius: 10px;
      background: rgba(0, 194, 255, 0.1);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1rem;
    }
    .card-icon i { font-size: 22px; color: var(--cyan); }

    .card h3 { font-size: 15px; font-weight: 600; color: #fff; margin-bottom: 0.4rem; }
    .card p { font-size: 13px; color: var(--muted); line-height: 1.5; }

    .badge {
      display: inline-block;
      font-size: 10px;
      font-weight: 700;
      padding: 3px 12px;
      border-radius: 20px;
      margin-top: 0.8rem;
      letter-spacing: 0.5px;
      text-transform: uppercase;
    }
    .badge-cyan { background: rgba(0, 194, 255, 0.1); color: var(--cyan); border: 1px solid rgba(0, 194, 255, 0.2); }
    .badge-teal { background: rgba(0, 255, 209, 0.08); color: var(--teal); border: 1px solid rgba(0, 255, 209, 0.2); }

    /* ===== HOME MODULES SECTION ===== */
    .modules-section {
      background: var(--dark2);
      border-top: 1px solid var(--border);
      padding: 2.5rem 2rem;
    }
    .modules-inner { max-width: 1200px; margin: 0 auto; }

    /* ===== INFO SECTION ===== */
    .info-block {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.4rem;
      margin-bottom: 1.2rem;
    }
    .info-block h3 {
      font-size: 15px;
      font-weight: 600;
      color: var(--cyan);
      margin-bottom: 0.8rem;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .info-block p { font-size: 13px; color: var(--muted); line-height: 1.65; }

    .type-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 14px;
      margin-top: 1rem;
    }

    .type-card {
      background: #060D1F;
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1rem;
    }

    .type-label {
      font-size: 12px;
      font-weight: 700;
      margin-bottom: 0.5rem;
      letter-spacing: 1px;
    }

    .type-desc { font-size: 12px; color: var(--muted); line-height: 1.5; }

    .steps { display: flex; flex-direction: column; gap: 12px; margin-top: 1rem; }

    .step { display: flex; gap: 14px; align-items: flex-start; }

    .step-num {
      min-width: 28px;
      height: 28px;
      background: rgba(0, 194, 255, 0.12);
      border: 1px solid rgba(0, 194, 255, 0.3);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      font-weight: 700;
      color: var(--cyan);
      flex-shrink: 0;
      margin-top: 2px;
    }

    .step-text { font-size: 13px; color: var(--text); line-height: 1.5; }
    .step-text strong { color: #fff; display: block; margin-bottom: 2px; font-size: 14px; }

    /* ===== LAB SECTION ===== */
    .lab-container {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
      margin-bottom: 2rem;
    }

    .metal-viewer {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.4rem;
    }

    .metal-viewer h3 {
      font-size: 13px;
      font-weight: 600;
      color: var(--cyan);
      margin-bottom: 1rem;
      font-family: 'Orbitron', sans-serif;
      letter-spacing: 1px;
    }

    .canvas-wrap {
      position: relative;
      height: 220px;
      border-radius: 10px;
      overflow: hidden;
      background: #060D1F;
      border: 1px solid var(--border);
      cursor: grab;
    }
    .canvas-wrap:active { cursor: grabbing; }

    canvas { width: 100%; height: 100%; display: block; }

    .canvas-hint {
      display: flex;
      justify-content: space-between;
      margin-top: 8px;
      font-size: 10px;
      color: var(--muted);
    }

    .metal-info { margin-top: 1rem; }
    .metal-name { font-size: 16px; font-weight: 600; color: #fff; margin-bottom: 0.3rem; }
    .metal-symbol { font-size: 12px; color: var(--cyan); font-weight: 600; margin-bottom: 0.5rem; }
    .metal-desc { font-size: 12px; color: var(--muted); line-height: 1.5; margin-bottom: 0.8rem; }

    .prop-row {
      display: flex;
      justify-content: space-between;
      font-size: 12px;
      padding: 5px 0;
      border-bottom: 1px solid rgba(26, 58, 106, 0.5);
    }
    .prop-row span:first-child { color: var(--muted); }
    .prop-row span:last-child { color: var(--cyan); font-weight: 600; }

    .metal-selector {
      display: flex;
      gap: 8px;
      margin-bottom: 1.2rem;
      flex-wrap: wrap;
    }

    .metal-btn {
      background: rgba(0, 194, 255, 0.06);
      border: 1px solid var(--border);
      color: var(--muted);
      font-size: 12px;
      font-weight: 500;
      padding: 6px 14px;
      border-radius: 30px;
      cursor: pointer;
      transition: all 0.2s;
      font-family: 'Inter', sans-serif;
    }
    .metal-btn:hover { background: rgba(0, 194, 255, 0.12); border-color: var(--cyan); color: var(--cyan); }
    .metal-btn.active { background: rgba(0, 194, 255, 0.18); border-color: var(--cyan); color: var(--cyan); }

    .tools-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 12px;
    }

    .tool-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.2rem;
      text-align: center;
      transition: all 0.2s;
      cursor: default;
    }
    .tool-card:hover { border-color: var(--teal); transform: translateY(-2px); }

    .tool-emoji { font-size: 30px; margin-bottom: 0.5rem; }
    .tool-name { font-size: 13px; font-weight: 600; color: #fff; margin-bottom: 0.2rem; }
    .tool-use { font-size: 11px; color: var(--muted); }

    /* ===== PROCEDIMIENTOS ===== */
    .proc-list { display: flex; flex-direction: column; gap: 14px; }

    .proc-item {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.4rem;
      display: flex;
      gap: 1.2rem;
      align-items: flex-start;
      transition: all 0.2s;
    }
    .proc-item:hover { border-color: rgba(0, 194, 255, 0.4); }

    .proc-num {
      font-family: 'Orbitron', sans-serif;
      font-size: 24px;
      font-weight: 700;
      color: rgba(0, 194, 255, 0.2);
      min-width: 44px;
    }

    .proc-body h4 { font-size: 15px; font-weight: 600; color: #fff; margin-bottom: 0.4rem; }
    .proc-body p { font-size: 13px; color: var(--muted); line-height: 1.55; }

    .proc-tags { display: flex; gap: 6px; margin-top: 0.7rem; flex-wrap: wrap; }

    .proc-tag {
      font-size: 10px;
      font-weight: 600;
      padding: 3px 10px;
      border-radius: 14px;
      background: rgba(0, 194, 255, 0.07);
      color: var(--cyan);
      border: 1px solid rgba(0, 194, 255, 0.15);
      letter-spacing: 0.5px;
    }

    /* ===== RECURSOS ===== */
    .resources-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 16px;
    }

    .res-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.4rem;
      transition: all 0.2s;
      display: flex;
      flex-direction: column;
    }
    .res-card:hover { border-color: rgba(0, 255, 209, 0.3); }

    .res-type { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.6rem; }
    .res-title { font-size: 15px; font-weight: 600; color: #fff; margin-bottom: 0.4rem; }
    .res-desc { font-size: 12px; color: var(--muted); line-height: 1.5; flex: 1; }

    .res-btn {
      margin-top: 1rem;
      width: 100%;
      background: rgba(0, 194, 255, 0.08);
      border: 1px solid rgba(0, 194, 255, 0.2);
      color: var(--cyan);
      font-size: 12px;
      font-weight: 600;
      padding: 9px;
      border-radius: 8px;
      cursor: pointer;
      transition: all 0.2s;
      font-family: 'Inter', sans-serif;
    }
    .res-btn:hover { background: rgba(0, 194, 255, 0.16); }

    /* ===== CONTACTO ===== */
    .contact-wrap {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
    }

    .contact-info { display: flex; flex-direction: column; gap: 14px; }

    .c-item {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.1rem 1.2rem;
      display: flex;
      gap: 14px;
      align-items: center;
    }

    .c-icon {
      width: 40px;
      height: 40px;
      background: rgba(0, 194, 255, 0.1);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .c-icon i { font-size: 20px; color: var(--cyan); }

    .c-text h4 { font-size: 13px; font-weight: 600; color: #fff; margin-bottom: 2px; }
    .c-text p { font-size: 12px; color: var(--muted); }

    .contact-form {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.5rem;
    }

    .contact-form h3 {
      font-size: 16px;
      font-weight: 700;
      color: #fff;
      margin-bottom: 1.2rem;
      font-family: 'Orbitron', sans-serif;
    }

    .form-field { margin-bottom: 1rem; }

    .form-field label {
      display: block;
      font-size: 11px;
      color: var(--muted);
      margin-bottom: 5px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.8px;
    }

    .form-field input,
    .form-field textarea,
    .form-field select {
      width: 100%;
      background: #060D1F;
      border: 1px solid var(--border);
      color: #fff;
      font-size: 13px;
      padding: 10px 14px;
      border-radius: 8px;
      font-family: 'Inter', sans-serif;
      outline: none;
      transition: border 0.2s;
      appearance: none;
    }
    .form-field input:focus,
    .form-field textarea:focus,
    .form-field select:focus { border-color: var(--cyan); }
    .form-field textarea { height: 90px; resize: none; }

    .form-send {
      width: 100%;
      background: var(--cyan);
      color: #060D1F;
      font-weight: 700;
      font-size: 13px;
      padding: 12px;
      border-radius: 9px;
      border: none;
      cursor: pointer;
      font-family: 'Orbitron', sans-serif;
      letter-spacing: 1.5px;
      transition: all 0.2s;
      margin-top: 0.4rem;
    }
    .form-send:hover { background: var(--cyan2); }

    /* ===== FOOTER ===== */
    footer {
      background: var(--dark2);
      border-top: 1px solid var(--border);
      padding: 1.4rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 10px;
    }

    .footer-logo {
      font-family: 'Orbitron', sans-serif;
      font-size: 15px;
      font-weight: 700;
      color: var(--cyan);
    }

    .footer-text { font-size: 12px; color: var(--muted); }

    /* ===== ANIMATIONS ===== */
    @keyframes rotateGear { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    @keyframes rotateGearRev { from { transform: rotate(360deg); } to { transform: rotate(0deg); } }
    @keyframes pulse { 0%, 100% { opacity: 0.5; } 50% { opacity: 1; } }

    .gear-ring { animation: rotateGear 14s linear infinite; transform-origin: 140px 140px; }
    .gear-ring2 { animation: rotateGearRev 9s linear infinite; transform-origin: 140px 140px; }
    .pulse-dot { animation: pulse 2.5s ease-in-out infinite; }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 768px) {
      .nav-links { display: none; }
      .nav-links.open { display: flex; flex-direction: column; position: absolute; top: 60px; left: 0; right: 0; background: rgba(6,13,31,0.98); padding: 1rem; border-bottom: 1px solid var(--border); gap: 4px; }
      .hamburger { display: block; }
      .hero h1 { font-size: 28px; }
      .hero-content { max-width: 100%; }
      .hero-visual { display: none; }
      .hero { padding: 2rem 1.2rem; }
      .lab-container, .contact-wrap { grid-template-columns: 1fr; }
      .section-content { padding: 1.5rem 1rem; }
      .modules-section { padding: 2rem 1rem; }
    }
  </style>
</head>
<body>

  <!-- NAVBAR -->
  <nav>
    <div class="logo">CRIST<span>O</span>LAB <span class="logo-ver">2.0</span></div>
    <button class="hamburger" onclick="toggleMenu()" aria-label="Menú">☰</button>
    <div class="nav-links" id="navLinks">
      <button class="nav-btn active" onclick="showSection('inicio', this)">Inicio</button>
      <button class="nav-btn" onclick="showSection('info', this)">Información</button>
      <button class="nav-btn" onclick="showSection('lab', this)">Laboratorio</button>
      <button class="nav-btn" onclick="showSection('proc', this)">Procedimientos</button>
      <button class="nav-btn" onclick="showSection('recursos', this)">Recursos</button>
      <button class="nav-btn" onclick="showSection('contacto', this)">Contacto</button>
    </div>
  </nav>

  <!-- ===== SECCIÓN: INICIO ===== -->
  <div id="inicio" class="section visible">
    <div class="hero">
      <div class="hero-bg"></div>
      <div class="hero-grid"></div>
      <div class="hero-glow"></div>

      <div class="hero-content">
        <div class="hero-tag">⚙ Laboratorio Virtual Industrial</div>
        <h1>Bienvenido a<br><span class="accent">CRISTOLAB 2.0</span></h1>
        <p>Plataforma interactiva de mantenimiento industrial con simulaciones 3D, análisis de materiales metálicos y procedimientos técnicos certificados bajo normas ISO.</p>
        <div class="hero-btns">
          <button class="btn-primary" onclick="showSection('lab', document.querySelectorAll('.nav-btn')[2])">Explorar Laboratorio</button>
          <button class="btn-secondary" onclick="showSection('info', document.querySelectorAll('.nav-btn')[1])">Ver Información</button>
        </div>
        <div class="hero-stats">
          <div class="stat">
            <div class="stat-num">12+</div>
            <div class="stat-label">Módulos</div>
